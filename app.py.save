    for message in st.session_state.messages:
        if message['role'] != 'system':
            with st.chat_message(message['role']):
                st.write(message['content'])

    enable_web = st.checkbox("🔍 Enable Live Web Context for the next prompt")

    if user_input := st.chat_input("Message your advanced chatbot..."):
        with st.chat_message("user"):
            st.write(user_input)
            
        final_prompt = user_input
        if enable_web:
            with st.spinner("Fetching live web text..."):
                web_facts = live_wikipedia_search(user_input)
                final_prompt = f"User Query: {user_input}\n\nLive Web context found:\n{web_facts}"
                
        if st.session_state.pdf_context:
            final_prompt = f"[REFERENCE ATTACHED PDF DATA FOR THIS ANSWER]\n{final_prompt}\n\nAttached Document Content:\n{st.session_state.pdf_context}"

        st.session_state.messages.append({'role': 'user', 'content': final_prompt})
        
        with st.chat_message("assistant"):
            if turbo_mode:
                if not cloud_key:
                    st.error("Please paste your OpenRouter API Key in the sidebar to use Turbo Mode! 🔑")
                else:
                    with st.spinner("Routing prompt to remote Cloud Supercomputer cluster... 🚀⚡"):
                        ai_reply = query_cloud_supercomputer(cloud_key, st.session_state.messages)
                        st.write(ai_reply)
                        st.session_state.messages.append({'role': 'assistant', 'content': ai_reply})
                        mac_speak(ai_reply)
                        st.rerun()
            else:
